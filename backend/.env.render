# Render: use PUBLIC Railway host (from MYSQL_PUBLIC_URL), NOT mysql.railway.internal
MYSQLHOST=crossover.proxy.rlwy.net
MYSQLPORT=21639
MYSQLUSER=root
MYSQLPASSWORD=your_railway_password
MYSQLDATABASE=railway
# Optional: paste Railway MYSQL_PUBLIC_URL as-is (mysql://...)
# MYSQL_PUBLIC_URL=mysql://root:password@crossover.proxy.rlwy.net:21639/railway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Optional — app starts without this; chatbot API disabled if omitted:
# OPENAI_API_KEY=sk-your-key-here
SPRING_PROFILES_ACTIVE=prod
